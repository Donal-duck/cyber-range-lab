# Secrets and credentials — NEVER commit these
*.key
*.pem
*.pfx
*.p12
*.crt
*.cer
*.pub
*_rsa
*_ed25519
*.ppk
id_*
secrets/
credentials/
.env
.env.*
*.secret
vault_pass*

# pfSense config backups may contain hashed credentials, interface MACs, VPN keys
*config-pfsense*.xml
pfSense-config*.xml

# BloodHound data contains full AD enumeration results
*.bloodhound
*_Bloodhound.zip
BloodHound_*/
*_users.json
*_groups.json
*_computers.json
*_domains.json
*_ous.json
*_gpos.json
*_containers.json

# Credential dumps and cracked hashes
*.ntds
ntds.dit
SYSTEM
SAM
SECURITY
*.kdbx
*.lsass
*.dmp
*_hashes.txt
*_cracked.txt
hashcat.potfile

# Loot and capture files
loot/
captures/
*.pcap
*.pcapng
responder-logs/

# C2 artefacts
implants/
*.implant
sliver/
cobalt/
*.beacon

# IDE / OS cruft
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/
venv/

# Terraform / Ansible state (may contain IPs, secrets)
*.tfstate
*.tfstate.backup
.terraform/
ansible/*.retry
